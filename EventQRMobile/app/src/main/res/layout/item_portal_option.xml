<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_quick_action"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp">

    <ImageView
        android:id="@+id/imgPortalIcon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_circle_purple_soft"
        android:padding="8dp"
        android:src="@drawable/ic_nav_home"
        app:tint="#5B25C9" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtPortalName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Attendee Portal"
            android:textColor="#111827"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtPortalSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Events, rewards, and your profile"
            android:textColor="#6B7280"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/currentPortalBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_success_chip"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:text="Current"
        android:textColor="#059669"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_chevron_right"
        app:tint="#D1D5DB" />
</LinearLayout>
